        "defaultColor": "#ff0034",
        "reloadButton": "♻️",
        "loadNpmCommands": false,
        "commands": [
            {
                "name": "Help",
                "color": "green",
                "useVsCodeApi": true,
                "command": "workbench.action.quickOpen",
                "args": [
                    ".help/helptoc.md",
                ]
            },
            {
                "name": "ToggleSpell",
                "color": "green",
                "useVsCodeApi": true,
                "command": "cSpell.toggleEnableSpellChecker",
            },
            {
                "name": "AllImages",
                "color": "green",
                "useVsCodeApi": true,
                "command": "vscode-infra.webviewImageViewer"
            },
            {
                "name": "GoTo",
                "color": "red",
                "useVsCodeApi": true,
                "command": "workbench.action.gotoLine",
            },
            {
                "name": "FoldAll",
                "color": "orange",
                "useVsCodeApi": true,
                "command": "editor.foldAll"
            },
            {
                "name": "Unfold",
                "color": "orange",
                "useVsCodeApi": true,
                "command": "editor.unfoldAll"
            },
            {
                "name": "FoldX",
                "color": "orange",
                "useVsCodeApi": true,
                "command": "editor.foldAllExcept"
            },
            {
                "name": "ExplorerSort",
                "color": "yellow",
                "useVsCodeApi": true,
                "command": "settings.cycle.explorerSort2"
            },
            {
                "name": "NewFile",
                "color": "yellow",
                "useVsCodeApi": true,
                "command": "ShortcutMenuBar.newFile"
            },
        ]
    },
