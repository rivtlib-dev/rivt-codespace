    "cmd image ( |im )": {
        "prefix": "|im",
        "description": "insert image",
        "scope": "python",
        "body": [
            "| IMAGE | rvsrc/img/${1:path} | ${2:caption}, ${3:scale}, ${4|num,non|}, ${5|time,not|} ${0}"
        ]
    },
    "cmd image2 ( |i2 )": {
        "prefix": "|i2",
        "description": "insert side by side images",
        "scope": "python",
        "body": [
            "| IMAGE2 | src/${1:path},src/${2:path} | ${3:scale},${4:scale},${5:caption},${6:caption} ${0:_[I]} "
        ]
    },
    "cmd pdfattach (  |pd  )": {
        "prefix": "|pd",
        "description": "attach pdf file - D api",
        "scope": "python",
        "body": [
            "| attachpdf | src/${1:path} | ${0:cover title} "
        ]
    },
    "cmd publish ( |pu )": {
        "prefix": "|pu",
        "description": "command publish doc - API rv.D",
        "scope": "python",
        "body": [
            "| PUBLISH | ${1:doc title} | ${0|pdf,html,txt,pdftex|}"
        ]
    },
    "cmd table ( |ta )": {
        "prefix": "|ta",
        "description": "command table from file - API rv.I and rv.V",
        "scope": "python",
        "body": [
            "| TABLE | src/${1:rel-path} | ${2:max-row-length}, [${3:start-row}:${4:end-row}] ${0:_[T]} "
        ]
    },
    "cmd text ( |te )": {
        "prefix": "|te",
