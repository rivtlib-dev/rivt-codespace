        ]
    },
    "Runx API ( rvr )": {
        "prefix": "rvr",
        "description": "API Run - short",
        "scope": "python",
        "body": [
            "rv.R(r\"\"\"${1:section-label} ",
            "",
            "    ${0:text}",
            "",
            "    \"\"\")"
        ]
    },
    "Run API ( rvrx )": {
        "prefix": "rvrx",
